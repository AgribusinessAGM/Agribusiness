# Copia este archivo a ".env" (en la raíz del repo) y rellena los valores
# para que las invitaciones envíen correos reales desde Microsoft 365 / Outlook.

# Cuenta de M365 que envía las invitaciones (ej. notificaciones@agromillora.com).
SMTP_USER=

# Contraseña de APLICACIÓN de esa cuenta — no la contraseña normal.
# Se genera en https://mysignins.microsoft.com/security-info (la cuenta necesita
# tener MFA activado para poder crear contraseñas de aplicación). Si tu
# administrador ha bloqueado la autenticación SMTP básica para el tenant
# (cada vez más frecuente por defecto), pídele que la active para este buzón:
# admin.microsoft.com > Usuarios > (la cuenta) > Correo > Administrar SMTP autenticado.
SMTP_PASS=

# Host/puerto SMTP — no suele haber que tocarlos para Microsoft 365.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587

# Remitente que verán los destinatarios (por defecto, el mismo que SMTP_USER).
FROM_EMAIL=

# URL pública donde corre el frontend — se usa para construir el enlace
# "crea tu contraseña" que se envía por correo.
APP_URL=http://localhost:5173

# Puerto del backend (opcional, por defecto 8787).
PORT=8787
