# Copia este archivo a ".env" (en la raíz del repo) y rellena los valores
# para que las invitaciones envíen correos reales.

# API key de Resend (https://resend.com) — Dashboard > API Keys.
RESEND_API_KEY=

# Remitente verificado en Resend (necesitas verificar un dominio propio para
# poder usar tu dirección; "onboarding@resend.dev" solo funciona en modo de
# pruebas y solo entrega a la cuenta con la que te registraste en Resend).
FROM_EMAIL=onboarding@resend.dev

# URL pública donde corre el frontend — se usa para construir el enlace
# "crea tu contraseña" que se envía por correo.
APP_URL=http://localhost:5173

# Puerto del backend (opcional, por defecto 8787).
PORT=8787
